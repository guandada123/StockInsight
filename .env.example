# StockInsight Pro 环境变量
# 复制为 .env 后修改

# Tushare API Token (用于数据下载和行业分类)
# 注册地址: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# Tushare 代理 API 地址 (可选，用于资金流向+行业分类增强)
# TUSHARE_API_URL=https://fastapia.stockai888.top

# 飞书群机器人 Webhook (可选，用于消息推送)
# 获取方式: 飞书群 → 设置 → 群机器人 → 添加自定义机器人
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
